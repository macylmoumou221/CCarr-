# ──────────────────────────────────────────
# CCarré – Variables d'environnement
# ──────────────────────────────────────────

# Serveur
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/ccarre

# JWT
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_64_CHARS_MIN
JWT_EXPIRES_IN=7d

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM=noreply@ccarre.fr

# URL de base de l'API (pour les liens dans les emails)
API_BASE_URL=http://localhost:5000
